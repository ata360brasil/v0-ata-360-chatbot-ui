# ═══════════════════════════════════════════════════════════════════════════════
# ATA360 — Variáveis de Ambiente
# Copie para .env.local e preencha os valores reais.
# NUNCA commite .env.local — apenas .env.example vai para o repositório.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ATA360
NEXT_PUBLIC_APP_ENV=development

# ─── Supabase (Paul Copplestone / supabase.com/docs) ─────────────────────────
# Projeto Supabase: Settings → API → Project URL + anon key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ─── Cloudflare Workers (Matthew Prince / developers.cloudflare.com) ──────────
NEXT_PUBLIC_WORKERS_URL=https://pncp-ata360.monostateorg.workers.dev
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# ─── AI Gateway — Multi-model (Cloudflare AI Gateway) ────────────────────────
# Gateway roteia para Claude, GPT, Gemini via endpoint unico
CLOUDFLARE_AI_GATEWAY_URL=https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_id}

# Claude (Anthropic) — 80% das chamadas (Haiku), 15% (Sonnet), 5% (Opus)
ANTHROPIC_API_KEY=sk-ant-...your-key
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_BALANCED=claude-sonnet-4-5-20250929
ANTHROPIC_MODEL_POWERFUL=claude-opus-4-6

# OpenAI — Embeddings + fallback
OPENAI_API_KEY=sk-...your-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini — fallback
GOOGLE_AI_API_KEY=AIza...your-key
GOOGLE_AI_MODEL=gemini-2.0-flash

# ─── Portal Transparencia (portaldatransparencia.gov.br/api-de-dados) ──────
PORTAL_TRANSPARENCIA_KEY=your-api-key

# ─── SERPRO (9 contratos / 17 serviços) ──────────────────────────────────────
SERPRO_CONSUMER_KEY=your-consumer-key
SERPRO_CONSUMER_SECRET=your-consumer-secret
SERPRO_ENV=producao

# ─── ClickHouse Cloud (Alexey Milovidov / clickhouse.com/docs) ───────────────
CLICKHOUSE_HOST=your-instance.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-password
CLICKHOUSE_DATABASE=ata360

# ─── Gov.br OAuth2 (manual-integracao.servicos.gov.br) ──────────────────────
GOVBR_CLIENT_ID=your-client-id
GOVBR_CLIENT_SECRET=your-client-secret
GOVBR_REDIRECT_URI=http://localhost:3000/api/auth/callback/govbr
GOVBR_AUTHORIZATION_URL=https://sso.acesso.gov.br/authorize
GOVBR_TOKEN_URL=https://sso.acesso.gov.br/token
GOVBR_USERINFO_URL=https://sso.acesso.gov.br/userinfo
GOVBR_TRUST_LEVEL=prata

# ─── Observability ───────────────────────────────────────────────────────────
# Escolha UM: axiom, datadog, ou api propria
NEXT_PUBLIC_OBSERVABILITY_ENDPOINT=
OBSERVABILITY_API_KEY=

# ─── Workers Security (obrigatório em produção) ────────────────────────────
# Shared secret entre BFF (Next.js) e Workers (Cloudflare)
WORKERS_SHARED_SECRET=generate-a-secure-random-string-here
# Secret para proteger endpoints de cron trigger contra acesso público
CRON_SECRET=generate-another-secure-random-string-here

# ─── Feature Flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_AI_SUGGESTIONS=true
NEXT_PUBLIC_ENABLE_INSIGHT_ENGINE=false
NEXT_PUBLIC_ENABLE_SEAL=false
NEXT_PUBLIC_ENABLE_SERPRO=false
